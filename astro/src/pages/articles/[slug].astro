---
import { getArticle } from "../../data/news";
import Layout from "../../layouts/Layout.astro";

const { slug } = Astro.params;
const article = slug ? await getArticle(slug) : null;

if (!article) {
  return Astro.redirect("/404", 302);
}
---

<Layout>
  <main>
    <p>{article.section}</p>
    <h1>{article.title}</h1>
    <p>{article.dek}</p>
    <img src={article.image.src} alt={article.image.alt} width={article.image.width} height={article.image.height} />
    <p>{article.byline} - {article.readTime}</p>
    {article.body.map((paragraph) => <p>{paragraph}</p>)}
  </main>
</Layout>

